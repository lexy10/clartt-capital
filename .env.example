# ============================================
# US30 Trading Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- General ---
NODE_ENV=development
LOG_LEVEL=info

# --- PostgreSQL ---
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading_secret
POSTGRES_DB=us30_trading
POSTGRES_PORT=5433

# --- Redis ---
REDIS_PORT=6380

# --- Dashboard ---
DASHBOARD_PORT=8080

# --- Backend (NestJS) ---
BACKEND_PORT=3000
JWT_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Strategy Engine (Python) ---
STRATEGY_ENGINE_PORT=8001
STRATEGY_ENGINE_API_PORT=8003
STRATEGY_MODE=live
SPREAD_THRESHOLD=5.0
VOLATILITY_MULTIPLIER=2.0
SLIPPAGE_TOLERANCE=3.0

# --- Execution Engine (Python) ---
EXECUTION_ENGINE_PORT=8002
METAAPI_TOKEN=
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_OPEN_POSITIONS=5
MAX_LOT_EXPOSURE=10.0
EXECUTION_LATENCY_THRESHOLD_MS=500

# --- Deriv API (Market Data) ---
DERIV_APP_ID=
DERIV_API_TOKEN=

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Circuit Breakers & Backpressure ---
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_MS=30000
CB_PROBE_INTERVAL_MS=10000
BACKPRESSURE_HIGH_WATER_MARK=100
BACKPRESSURE_LOW_WATER_MARK=20
CONSUMER_LAG_ALERT_THRESHOLD=50
CONSUMER_LAG_POLL_INTERVAL_MS=10000
SIGNAL_BUFFER_MAX_SIZE=500
BACKTEST_REQUEST_HIGH_WATER_MARK=10
BACKTEST_RESULT_HIGH_WATER_MARK=50

# --- Event Sourcing ---
EVENT_RETENTION_DAYS=90
EVENT_ARCHIVE_RETENTION_DAYS=365
