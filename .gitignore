# ─── Secrets & local config ────────────────────────────────────────────
# Real env files contain broker tokens, DB passwords, JWT secrets.
# Commit .env.example as a template instead.
.env
.env.*
!.env.example
*.stale.bak
*.local

# Broker credentials / API keys floating around the repo
**/credentials.json
**/*.pem
**/*.key
**/*service-account*.json

# ─── Node / TypeScript ─────────────────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo
.npm/
.yarn/
.pnpm-store/

# ─── Python ────────────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/

# ─── Vite / React build artifacts ──────────────────────────────────────
packages/dashboard/dist/
.vite/

# ─── Docker / infra runtime ────────────────────────────────────────────
# Volumes live in docker's storage, not the repo — but stray dumps end
# up in the working tree sometimes.
*.dump
*.sql.gz
postgres-data/
redis-data/

# ─── Logs ──────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── IDE / editor ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Misc Claude / AI tooling ──────────────────────────────────────────
.claude/
.kiro/
scripts